---
const links = [
  { href: '/',        label: 'Home'    },
  { href: '/blog',    label: 'Blog'    },
  { href: '/videos',  label: 'Videos'  },
  { href: '/contact', label: 'Contact' },
];

const { pathname } = Astro.url;
---

<nav>
  <a href="/" class="nav-logo">
    <span class="bracket">[</span>TFC<span class="bracket">]</span>
  </a>

  <ul class="nav-links">
    {links.map(l => (
      <li>
        <a
          href={l.href}
          class:list={['nav-link', { active: pathname === l.href || (l.href !== '/' && pathname.startsWith(l.href)) }]}
        >
          {l.label}
        </a>
      </li>
    ))}
  </ul>

  <a href="/contact" class="nav-cta">Get in Touch</a>

  <button class="hamburger" id="hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobile-menu">
  {links.map(l => (
    <a href={l.href} class="mobile-link">{l.label}</a>
  ))}
</div>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 5%;
    height: 60px;
    background: rgba(8, 8, 16, 0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--rule);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.02em;
  }
  .bracket { color: var(--amber); font-weight: 300; }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--text); }
  .nav-link.active { color: var(--amber); }

  .nav-cta {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 18px;
    border: 1px solid var(--amber);
    color: var(--amber);
    border-radius: 1px;
    transition: background 0.15s, color 0.15s;
  }
  .nav-cta:hover { background: var(--amber); color: #000; }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--text);
    transition: opacity 0.2s;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 60px; left: 0; right: 0;
    background: var(--bg-card);
    border-bottom: 1px solid var(--rule);
    flex-direction: column;
    z-index: 98;
  }
  .mobile-menu.open { display: flex; }

  .mobile-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 18px 5%;
    border-bottom: 1px solid var(--rule);
    transition: color 0.15s;
  }
  .mobile-link:hover { color: var(--text); }

  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('open'));
</script>