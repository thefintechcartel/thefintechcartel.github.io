---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with The Fintech Cartel.">
  <div class="contact-wrapper">

    <div class="contact-header">
      <div class="contact-label">// get in touch</div>
      <h1>Contact</h1>
      <p>Ideas, collabs, feedback, or just want to argue about interest rates — we're here for it.</p>
    </div>

    <div class="contact-inner">
      <div class="contact-links">
        <a class="contact-link" href="https://instagram.com/thefintechcartel" target="_blank" rel="noopener">
          <div class="link-icon">ig</div>
          <div>
            <div class="link-label">Instagram</div>
            <div class="link-val">@thefintechcartel</div>
          </div>
        </a>
        <a class="contact-link" href="mailto:thefintechcartel@gmail.com">
          <div class="link-icon">✉</div>
          <div>
            <div class="link-label">Email</div>
            <div class="link-val">thefintechcartel@gmail.com</div>
          </div>
        </a>
      </div>

      <form class="contact-form" action="https://formspree.io/f/xjgdlqez" method="POST">
        <input type="hidden" name="_next" value="https://thefintechcartel.github.io/contact" />

        <div class="form-row">
          <div class="form-group">
            <label for="name">Name</label>
            <input id="name" type="text" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" placeholder="your@email.com" required />
          </div>
        </div>
        <div class="form-group">
          <label for="subject">Subject</label>
          <input id="subject" type="text" name="subject" placeholder="Collab, feedback, question..." />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" placeholder="What's on your mind?" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn-primary">Send Message →</button>
      </form>
    </div>

  </div>
</Base>

<style>
  .contact-wrapper { padding: 64px 40px 80px; }

  .contact-header {
    margin-bottom: 64px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--rule);
  }

  .contact-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--green);
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .contact-header p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
    align-items: start;
  }

  .contact-links { display: flex; flex-direction: column; gap: 2px; }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 0;
    border-bottom: 1px solid var(--rule);
    transition: opacity 0.15s;
  }
  .contact-link:hover { opacity: 0.6; }

  .link-icon {
    width: 38px; height: 38px;
    border: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: var(--green);
    flex-shrink: 0;
  }

  .link-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .link-val { font-size: 13px; font-weight: 600; }

  /* FORM */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group { display: flex; flex-direction: column; gap: 8px; }

  label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  input, textarea {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    padding: 12px 14px;
    color: var(--text);
    font-family: var(--font);
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    resize: vertical;
  }
  input:focus, textarea:focus { border-color: var(--green); }
  input::placeholder, textarea::placeholder { color: var(--muted); opacity: 0.5; }

  @media (max-width: 768px) {
    .contact-wrapper { padding: 48px 24px 60px; }
    .contact-inner { grid-template-columns: 1fr; gap: 48px; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>