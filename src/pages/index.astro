---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recent = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base title="Home">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <div class="eyebrow">The Fintech Cartel</div>
      <h1>
        Where <em class="accent">Finance</em><br />
        meets the<br />
        <span class="stroke-text">Future.</span>
      </h1>
      <p class="hero-sub">
        Sharp takes on markets, technology, and the systems quietly reshaping money —
        from two students who actually read the footnotes.
      </p>
      <div class="hero-actions">
        <a href="/blog" class="btn-primary">Read the Blog →</a>
        <a href="/videos" class="btn-ghost">Watch Videos</a>
      </div>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">2</div>
        <div class="stat-label">Writers</div>
      </div>
      <div class="stat">
        <div class="stat-num">∞</div>
        <div class="stat-label">Hot takes</div>
      </div>
      <div class="stat">
        <div class="stat-num">0</div>
        <div class="stat-label">Paywalls</div>
      </div>
      <div class="stat stat-right">
        <div class="stat-mono">EST. 2025</div>
        <div class="stat-label">India</div>
      </div>
    </div>
  </section>

  <!-- RECENT POSTS -->
  {recent.length > 0 && (
    <section class="recent">
      <div class="section-head">
        <div class="eyebrow" style="margin-bottom:0">Latest</div>
        <a href="/blog" class="see-all">All posts →</a>
      </div>
      <div class="post-grid">
        <!-- Featured first post -->
        <a href={`/blog/${recent[0].id}`} class="post-card post-card--featured">
          <div class="card-top">
            <span class:list={['tag', recent[0].data.category === 'Finance' ? 'tag-finance' : 'tag-tech']}>
              {recent[0].data.category}
            </span>
            <span class="card-date">
              {recent[0].data.pubDate.toLocaleDateString('en-IN', { month: 'short', day: 'numeric' })}
            </span>
          </div>
          <h3>{recent[0].data.title}</h3>
          <p>{recent[0].data.description}</p>
          <div class="card-footer">
            <span class="card-author">{recent[0].data.author}</span>
            <span class="card-arrow">→</span>
          </div>
        </a>

        <!-- Remaining posts -->
        <div class="post-stack">
          {recent.slice(1).map(post => (
            <a href={`/blog/${post.id}`} class="post-card post-card--small">
              <div class="card-top">
                <span class:list={['tag', post.data.category === 'Finance' ? 'tag-finance' : 'tag-tech']}>
                  {post.data.category}
                </span>
                <span class="card-date">
                  {post.data.pubDate.toLocaleDateString('en-IN', { month: 'short', day: 'numeric' })}
                </span>
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="card-footer">
                <span class="card-author">{post.data.author}</span>
                <span class="card-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ABOUT STRIP -->
  <section class="about-strip">
    <div class="about-inner">
      <div class="about-text">
        <div class="eyebrow">Who we are</div>
        <h2>Two students.<br />One obsession.</h2>
        <p>
          Adyaan breaks down markets, policies, and why your money does what it does.
          Advik covers the tech stacks, startups, and systems that make modern finance run.
          No jargon for its own sake. No hype.
        </p>
      </div>
      <div class="team-cards">
        <div class="team-card">
          <div class="avatar avatar--amber">A</div>
          <div>
            <div class="member-name">Adyaan</div>
            <div class="member-role">Finance</div>
          </div>
        </div>
        <div class="team-card">
          <div class="avatar avatar--blue">A</div>
          <div>
            <div class="member-name">Advik</div>
            <div class="member-role">Tech</div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── HERO ── */
  .hero {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-bottom: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--rule) 1px, transparent 1px),
      linear-gradient(90deg, var(--rule) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.5;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    padding: 72px 5% 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  h1 {
    font-size: clamp(48px, 9vw, 108px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    max-width: 900px;
    margin-bottom: 28px;
  }

  .accent { font-style: normal; color: var(--amber); }

  .stroke-text {
    -webkit-text-stroke: 1.5px var(--muted-mid);
    color: transparent;
    display: inline-block;
  }

  .hero-sub {
    font-size: 15px;
    color: var(--muted);
    max-width: 420px;
    line-height: 1.75;
    margin-bottom: 40px;
    font-weight: 400;
  }

  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  .hero-stats {
    position: relative;
    display: flex;
    align-items: stretch;
    border-top: 1px solid var(--rule);
    margin-top: 64px;
  }

  .stat {
    padding: 24px 5%;
    border-right: 1px solid var(--rule);
    flex: 1;
  }
  .stat-right {
    margin-left: auto;
    flex: 0;
    min-width: 120px;
    text-align: right;
    border-right: none;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-mono {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 400;
    line-height: 1;
    margin-bottom: 6px;
    color: var(--text);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ── RECENT ── */
  .recent {
    padding: 64px 5%;
    border-bottom: 1px solid var(--rule);
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .see-all {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.08em;
    transition: color 0.15s;
  }
  .see-all:hover { color: var(--amber); }

  .post-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .post-stack {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--rule);
  }

  .post-card {
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 0.15s;
    cursor: pointer;
  }
  .post-card:hover { background: var(--bg-hover); }
  .post-card:hover .card-arrow { transform: translateX(4px); }

  .post-card--featured { padding: 36px; }
  .post-card--small    { padding: 24px 28px; }

  .post-card--featured h3 {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .post-card--small h3 {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .post-card p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    border-top: 1px solid var(--rule);
    margin-top: auto;
  }

  .card-author {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
  }

  .card-arrow {
    color: var(--amber);
    font-size: 14px;
    transition: transform 0.2s;
  }

  /* ── ABOUT ── */
  .about-strip { padding: 64px 5%; }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 80px;
    align-items: center;
  }

  .about-text h2 {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .about-text p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.8;
    max-width: 420px;
  }

  .team-cards { display: flex; flex-direction: column; gap: 12px; }

  .team-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 18px 22px;
    min-width: 210px;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: #000;
    flex-shrink: 0;
  }
  .avatar--amber { background: var(--amber); }
  .avatar--blue  { background: #3b82f6; }

  .member-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
  }
  .member-role {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 3px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .post-grid { grid-template-columns: 1fr; }
    .about-inner { grid-template-columns: 1fr; gap: 40px; }
    .hero-stats { flex-wrap: wrap; }
    .stat-right { border-left: 1px solid var(--rule); text-align: left; }
  }
</style>