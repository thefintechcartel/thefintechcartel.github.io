---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by category for filter tabs
const categories = ['All', 'Finance', 'Tech'];
---

<Base title="Blog" description="Finance and tech writing from The Fintech Cartel.">
  <div class="blog-wrapper">

    <div class="blog-header">
      <div class="eyebrow">The Blog</div>
      <h1>From the Desk</h1>
      <p>Finance deep-dives from Adyaan. Tech breakdowns from us. No fluff.</p>
    </div>

    <!-- Filter tabs (client-side JS below) -->
    <div class="filter-tabs">
      {categories.map(cat => (
        <button class:list={['tab', { active: cat === 'All' }]} data-filter={cat}>
          {cat}
        </button>
      ))}
    </div>

    {posts.length === 0 ? (
      <div class="empty">
        <p>Posts coming soon. Check back shortly.</p>
      </div>
    ) : (
      <div class="post-grid" id="post-grid">
        {posts.map(post => (
          <a
            href={`/blog/${post.id}`}
            class="post-card"
            data-category={post.data.category}
          >
            <div class="card-top">
              <span class:list={['tag', post.data.category === 'Finance' ? 'tag-finance' : 'tag-tech']}>
                {post.data.category}
              </span>
              <span class="card-date">
                {post.data.pubDate.toLocaleDateString('en-IN', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <div class="card-footer">
              <span class="card-author">{post.data.author}</span>
              <span class="card-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    )}

  </div>
</Base>

<style>
  .blog-wrapper { padding: 64px 5% 80px; }

  .blog-header {
    margin-bottom: 56px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--rule);
  }

  h1 {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .blog-header p {
    font-size: 16px;
    color: var(--muted);
  }

  .filter-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 40px;
  }

  .tab {
    font-family: var(--font-head);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 20px;
    background: none;
    border: 1px solid var(--rule);
    color: var(--muted);
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .tab:hover { color: var(--text); border-color: var(--muted); }
  .tab.active { background: var(--amber); color: #000; border-color: var(--amber); }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .post-card {
    background: var(--bg-card);
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.2s;
  }
  .post-card:hover { background: var(--bg-hover); }
  .post-card[style*="display: none"] { display: none !important; }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .card-date {
    font-family: var(--font-head);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  h2 {
    font-family: var(--font-head);
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .post-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
    margin-top: auto;
  }
  .card-author {
    font-size: 12px;
    color: var(--muted);
    font-family: var(--font-head);
  }
  .card-arrow {
    color: var(--amber);
    transition: transform 0.2s;
  }
  .post-card:hover .card-arrow { transform: translateX(4px); }

  .empty {
    padding: 80px 0;
    text-align: center;
    color: var(--muted);
    font-family: var(--font-head);
    font-size: 14px;
    letter-spacing: 0.06em;
    border: 1px dashed var(--rule);
  }
</style>

<script>
  // Category filter
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter;

      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      cards.forEach(card => {
        const match = filter === 'All' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
