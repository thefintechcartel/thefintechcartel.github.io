---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  category: string;
  tags: string[];
}

const { title, description, pubDate, author, category, tags } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-IN', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<Base title={title} description={description}>
  <article class="post-wrapper">

    <header class="post-header">
      <div class="post-meta-row">
        <span class:list={['tag', category === 'Finance' ? 'tag-finance' : 'tag-tech']}>
          {category}
        </span>
        <span class="meta-sep" aria-hidden="true">/</span>
        <span class="post-date">{formatted}</span>
      </div>

      <h1>{title}</h1>
      <p class="post-desc">{description}</p>

      <div class="post-author">
        <div class:list={['author-av', author.toLowerCase().includes('advik') ? 'author-av--blue' : 'author-av--amber']}>
          {author[0]}
        </div>
        <div>
          <div class="author-name">{author}</div>
          <div class="author-role">{category === 'Finance' ? 'Finance' : 'Tech'}</div>
        </div>
      </div>

      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(t => <span class="inline-tag">#{t}</span>)}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/blog" class="btn-ghost">← Back to Blog</a>
    </footer>

  </article>
</Base>

<style>
  .post-wrapper {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 5% 80px;
  }

  .post-header {
    margin-bottom: 56px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--rule);
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .meta-sep {
    color: var(--rule);
    font-size: 14px;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  h1 {
    font-size: clamp(28px, 5vw, 54px);
    font-weight: 700;
    margin-bottom: 20px;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .post-desc {
    font-size: 17px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 32px;
    font-weight: 400;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .author-av {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: #000;
    flex-shrink: 0;
  }
  .author-av--amber { background: var(--amber); }
  .author-av--blue  { background: #3b82f6; }

  .author-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
  }
  .author-role {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
  }

  .inline-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.06em;
    transition: color 0.15s;
  }
  .inline-tag:hover { color: var(--amber); }

  .post-footer {
    margin-top: 72px;
    padding-top: 40px;
    border-top: 1px solid var(--rule);
  }
</style>